    "previewHtml": "<style>\n  .banner {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    background: #FFFFFF;\n    padding: 16px 24px;\n    border-radius: 8px;\n    border: 0.5px solid #E0E1E6;\n    box-shadow: 0px 12px 20px rgba(28, 32, 36, 0.1);\n    gap: 16px;\n    min-width: 480px;\n  }\n  .banner__title {\n    color: #1C2024;\n    font-size: 16px;\n    font-weight: 500;\n    line-height: 24px;\n  }\n  .banner__body {\n    color: #60646C;\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 20px;\n  }\n  .banner__actions {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n  }\n  .banner__btn {\n    font-size: 16px;\n    font-style: normal;\n    font-weight: 500;\n    line-height: 24px;\n    border-radius: 6px;\n    padding: 8px 16px;\n    border: 0.5px solid #1C2024;\n    background: #1C2024;\n    color: #FCFCFD;\n  }\n  .banner__btn--secondary {\n    border-color: #D9D9E0;\n    background: #FFFFFF;\n    color: #1C2024;\n  }\n  .banner__close {\n    padding: 11px;\n    border: none;\n    background: none;\n    line-height: 0;\n  }\n</style>\n<div class=\"banner\">\n  <div class=\"banner__message\">\n    <div class=\"banner__title\">\n      {{ title }}\n    </div>\n    <div class=\"banner__body\">\n      {{ body }}\n    </div>\n  </div>\n  <div class=\"banner__actions\">\n    {% if variant == \"multi-action\" %}\n      <button class=\"banner__btn banner__btn--secondary\">\n        {{ secondary_button.text }}\n      </button>\n    {% endif %}\n\n    {% if variant == \"single-action\" or variant == \"multi-action\" %}\n      <button class=\"banner__btn\">\n        {{ primary_button.text }}\n      </button>\n    {% endif %}\n\n    {% if dismissible %}\n      <button class=\"banner__close\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"none\">\n          <g fill=\"#60646C\" fill-rule=\"evenodd\" clip-rule=\"evenodd\">\n            <path d=\"M14.03 3.97a.75.75 0 0 1 0 1.06l-9 9a.75.75 0 0 1-1.06-1.06l9-9a.75.75 0 0 1 1.06 0Z\"/>\n            <path d=\"M3.97 3.97a.75.75 0 0 1 1.06 0l9 9a.75.75 0 1 1-1.06 1.06l-9-9a.75.75 0 0 1 0-1.06Z\"/>\n          </g>\n        </svg>\n      </button>\n    {% endif %}\n  </div>\n</div>",
