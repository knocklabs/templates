    "previewHtml": "<style>\n.announcement-card {\n  background: white;\n  border: 1px solid #dfe2e5;\n  border-radius: 8px;\n  margin: 16px;\n  margin-bottom: 16px;\n  cursor: pointer;\n  font-family: Inter, sans-serif;\n  display: flex;\n  flex-direction: column;\n}\n\n.announcement-card .image-section {\n  background: #efece7;\n  height: 240px;\n  width: 100%;\n  position: relative;\n  overflow: hidden;\n  border-radius: 8px 8px 0 0;\n}\n\n.announcement-card .image {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  object-position: center;\n}\n\n.announcement-card .content-section {\n  padding: 12px 16px;\n}\n\n.announcement-card .title {\n  font-size: 16px;\n  font-weight: 500;\n  line-height: 24px;\n  color: #1c2024;\n  margin: 0 0 8px 0;\n}\n\n.announcement-card .body {\n  font-size: 12px;\n  font-weight: 400;\n  line-height: 16px;\n  color: #60646a;\n  letter-spacing: 0.0275px;\n  margin: 0;\n}\n\n.announcement-card .body p {\n  margin: 0;\n}\n\n.announcement-card .button-group {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  justify-content: flex-end;\n  padding: 0 12px 12px 12px;\n}\n\n.announcement-card .button {\n  flex: 1;\n  height: 32px;\n  padding: 0 8px;\n  border-radius: 4px;\n  font-size: 13px;\n  font-weight: 500;\n  line-height: 20px;\n  cursor: pointer;\n  border: none;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.announcement-card .button-primary {\n  background: #1d2023;\n  color: #fcfcfd;\n}\n\n.announcement-card .button-primary:hover {\n  background: #2c3034;\n}\n\n.announcement-card .button-secondary {\n  background: white;\n  color: #1d2023;\n  border: 1px solid #d7dadf;\n}\n\n.announcement-card .button-secondary:hover {\n  background: #f9fafb;\n}\n</style>\n<div class=\"announcement-card\">\n  <div class=\"image-section\">\n    <img src=\"{{ image.url }}\" alt=\"{{ image.alt }}\" class=\"image\" />\n  </div>\n  \n  <div class=\"content-section\">\n    <h3 class=\"title\">{{ title }}</h3>\n    <div class=\"body\">\n      <p>{{ body }}</p>\n    </div>\n  </div>\n  \n  <div class=\"button-group\">\n    <button class=\"button button-primary\">{{ primary_button.text }}</button>\n    <button class=\"button button-secondary\">{{ secondary_button.text }}</button>\n  </div>\n</div>",
    "selectedVariant": "default",
    "previewImage": "metadata/images/components/feature-announcement/cover.png",
    "ogImage": "metadata/images/components/feature-announcement/og.png",
    "cliCommand": "npx @knocklabs/cli guide new --template=feature-announcement"
  }
