{
  "name": "Usage threshold alerts",
  "steps": [
    {
      "name": "Check severity",
      "type": "branch",
      "description": "Route alerts based on threshold severity",
      "ref": "branch_1",
      "branches": [
        {
          "name": "Critical",
          "conditions": {
            "all": [
              {
                "variable": "data.threshold.severity",
                "operator": "equal_to",
                "argument": "critical"
              }
            ]
          },
          "steps": [
            {
              "name": "Email",
              "type": "channel",
              "description": "Send critical threshold alert via email",
              "template": {
                "subject": "Critical: {{ data.threshold.metric_name }} at {{ data.threshold.percent }}%",
                "is_mjml": false,
                "settings": {
                  "layout_key": "default",
                  "attachment_key": "attachments"
                },
                "visual_blocks@": "email_1/visual_blocks.json"
              },
              "ref": "email_1",
              "channel_type": "email",
              "conditions": {
                "all": [
                  {
                    "variable": "data.threshold.channels",
                    "operator": "contains",
                    "argument": "email"
                  }
                ]
              },
              "channel_key": "knock-email"
            },
            {
              "name": "SMS",
              "type": "channel",
              "description": "Send critical threshold alert via SMS",
              "template": {
                "settings": {},
                "text_body@": "sms_1/text_body.txt"
              },
              "ref": "sms_1",
              "channel_type": "sms",
              "conditions": {
                "all": [
                  {
                    "variable": "data.threshold.channels",
                    "operator": "contains",
                    "argument": "sms"
                  }
                ]
              },
              "channel_key": "twilio"
            }
          ],
          "terminates": false
        },
        {
          "name": "Warning",
          "steps": [
            {
              "name": "Email",
              "type": "channel",
              "description": "Send warning threshold alert via email",
              "template": {
                "subject": "Warning: {{ data.threshold.metric_name }} at {{ data.threshold.percent }}%",
                "is_mjml": false,
                "settings": {
                  "layout_key": "default",
                  "attachment_key": "attachments"
                },
                "visual_blocks@": "email_2/visual_blocks.json"
              },
              "ref": "email_2",
              "channel_type": "email",
              "conditions": {
                "all": [
                  {
                    "variable": "data.threshold.channels",
                    "operator": "contains",
                    "argument": "email"
                  }
                ]
              },
              "channel_key": "knock-email"
            }
          ],
          "terminates": false
        }
      ]
    }
  ],
  "trigger_frequency": "every_trigger",
  "__readonly": {
    "key": "usage-threshold-alerts",
    "active": true,
    "valid": true
  },
  "$schema": "https://schemas.knock.app/cli/workflow.json"
}
