{
  "name": "Email verification",
  "steps": [
    {
      "name": "Email",
      "type": "channel",
      "description": "Send email verification link",
      "template": {
        "subject": "Verify your email for Knock",
        "settings": {
          "layout_key": "default",
          "attachment_key": "attachments"
        },
        "visual_blocks@": "email_1/visual_blocks.json"
      },
      "ref": "email_1",
      "channel_type": "email",
      "channel_key": "knock-email"
    },
    {
      "name": "Delay",
      "type": "delay",
      "description": "Wait before sending reminder",
      "ref": "delay_1",
      "settings": {
        "delay_for": {
          "unit": "hours",
          "value": 24
        }
      }
    },
    {
      "name": "Email",
      "type": "channel",
      "description": "Send verification reminder",
      "template": {
        "subject": "Reminder: Verify your email for Knock",
        "settings": {
          "layout_key": "default",
          "attachment_key": "attachments"
        },
        "visual_blocks@": "email_2/visual_blocks.json"
      },
      "ref": "email_2",
      "channel_type": "email",
      "channel_key": "knock-email"
    }
  ],
  "trigger_frequency": "every_trigger",
  "__readonly": {
    "key": "email-verification",
    "active": true,
    "valid": true
  },
  "$schema": "https://schemas.knock.app/cli/workflow.json"
}
