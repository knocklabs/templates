{
  "name": "First milestone",
  "steps": [
    {
      "channel_key": "in-app-feed",
      "channel_type": "in_app_feed",
      "description": "Celebrate first milestone in-app",
      "name": "In-app feed",
      "ref": "in_app_feed_1",
      "template": {
        "action_url": "{{ data.milestone.url }}",
        "markdown_body@": "in_app_feed_1/markdown_body.md"
      },
      "type": "channel"
    },
    {
      "description": "Wait before escalating",
      "name": "Delay",
      "ref": "delay_1",
      "settings": {
        "delay_for": {
          "unit": "hours",
          "value": 8
        }
      },
      "type": "delay"
    },
    {
      "channel_key": "postmark",
      "channel_type": "email",
      "conditions": {
        "all": [
          {
            "argument": "$message.seen",
            "operator": "less_than",
            "variable": "refs.in_app_feed_1.status"
          }
        ]
      },
      "description": "Send milestone email if unseen",
      "name": "Email",
      "ref": "email_1",
      "template": {
        "settings": {
          "attachment_key": "attachments",
          "layout_key": "default"
        },
        "subject": "You hit a milestone: {{ data.milestone.name }} 🎉",
        "visual_blocks@": "email_1/visual_blocks.json"
      },
      "type": "channel"
    }
  ],
  "trigger_frequency": "every_trigger",
  "__readonly": {
    "environment": "development",
    "key": "first-milestone",
    "active": true,
    "valid": true,
    "created_at": "2026-06-25T00:00:00.000000Z"
  },
  "$schema": "https://schemas.knock.app/cli/workflow.json"
}
