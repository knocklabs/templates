{
  "name": "Changelog modal",
  "description": "Displays a modal with one or more changelog announcements.",
  "variants": [
    {
      "name": "Default",
      "fields": [
        {
          "label": "Eyebrow text",
          "type": "text",
          "key": "eyebrowText",
          "settings": {
            "default": "New in Knock",
            "required": false,
            "max_length": 32
          }
        },
        {
          "label": "Title",
          "type": "text",
          "key": "title",
          "settings": {
            "default": "Modal title",
            "required": true,
            "max_length": 32,
            "min_length": 3
          }
        },
        {
          "label": "Body",
          "type": "textarea",
          "key": "body",
          "settings": {
            "default": "Copy about the feature or general information to highlight.",
            "required": true,
            "max_length": 200,
            "min_length": 10
          }
        },
        {
          "label": "Link text",
          "type": "text",
          "key": "link",
          "settings": {
            "default": "Link to changelog, release notes, or feature.",
            "required": false
          }
        },
        {
          "label": "Image",
          "type": "image",
          "key": "image",
          "action": {
            "label": "Image action",
            "type": "text",
            "key": "action",
            "settings": {
              "default": "",
              "required": false
            }
          },
          "alt": {
            "label": "Alt text",
            "type": "text",
            "key": "alt",
            "settings": {
              "default": "",
              "required": false
            }
          },
          "settings": {
            "required": true
          },
          "url": {
            "label": "Image URL",
            "type": "url",
            "key": "url",
            "settings": {
              "default": "https://assets.knock.app/example-changelog.png",
              "required": true
            }
          }
        }
      ],
      "key": "default"
    }
  ],
  "icon_name": "Flag",
  "preview@": "preview.html",
  "__readonly": {
    "key": "changelog-modal",
    "valid": true,
    "owner": "user",
    "semver": "0.0.2"
  },
  "$schema": "https://schemas.knock.app/cli/message-type.json"
}
