{
  "name": "Announcement Card",
  "description": "A card displayed in the sidebar to reinforce announcements",
  "variants": [
    {
      "name": "Default",
      "fields": [
        {
          "label": "Title example",
          "type": "text",
          "key": "title",
          "settings": {
            "default": "Card title",
            "required": true,
            "max_length": 32,
            "min_length": 3
          }
        },
        {
          "label": "Body",
          "type": "textarea",
          "key": "body",
          "settings": {
            "default": "Copy about the feature or general information to highlight.",
            "required": true,
            "max_length": 200,
            "min_length": 10
          }
        },
        {
          "label": "Dismissible?",
          "type": "boolean",
          "key": "dismissible",
          "settings": {
            "default": true,
            "required": false
          }
        },
        {
          "label": "Image",
          "type": "image",
          "key": "image",
          "action": {
            "label": "Image action",
            "type": "text",
            "key": "action",
            "settings": {
              "default": "",
              "required": false
            }
          },
          "alt": {
            "label": "Alt text",
            "type": "text",
            "key": "alt",
            "settings": {
              "default": "",
              "required": false
            }
          },
          "settings": {
            "required": true
          },
          "url": {
            "label": "Image URL",
            "type": "url",
            "key": "url",
            "settings": {
              "default": "https://assets.knock.app/example-announcement.png",
              "required": true
            }
          }
        },
        {
          "label": "Primary Button",
          "type": "button",
          "text": {
            "label": "Button Text",
            "type": "text",
            "key": "text",
            "settings": {
              "default": "Primary",
              "required": true,
              "max_length": 20,
              "min_length": 1
            }
          },
          "key": "primary_button",
          "action": {
            "label": "Button Action",
            "type": "text",
            "key": "action",
            "settings": {
              "default": "/features/guides",
              "required": true,
              "max_length": 100,
              "min_length": 1
            }
          },
          "settings": {
            "description": "Primary action button",
            "required": true
          }
        },
        {
          "label": "Secondary Button",
          "type": "button",
          "text": {
            "label": "Button Text",
            "type": "text",
            "key": "text",
            "settings": {
              "default": "Secondary",
              "required": true,
              "max_length": 20,
              "min_length": 1
            }
          },
          "key": "secondary_button",
          "action": {
            "label": "Button Action",
            "type": "text",
            "key": "action",
            "settings": {
              "default": "https://docs.knock.app",
              "required": true,
              "max_length": 100,
              "min_length": 1
            }
          },
          "settings": {
            "description": "Secondary action button",
            "required": true
          }
        }
      ],
      "key": "default"
    }
  ],
  "icon_name": "Megaphone",
  "preview@": "preview.html",
  "__readonly": {
    "key": "announcement-card",
    "valid": true,
    "owner": "user",
    "semver": "0.0.2"
  },
  "$schema": "https://schemas.knock.app/cli/message-type.json"
}
