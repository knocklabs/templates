{
  "name": "NPS survey",
  "description": "A modal overlay with rating scale that displays in the lower-right corner of our app.",
  "variants": [
    {
      "name": "Default",
      "fields": [
        {
          "label": "Company name",
          "type": "text",
          "key": "companyName",
          "settings": {
            "default": "Acme Inc.",
            "description": "The company name to insert into the NPS survey",
            "required": true,
            "max_length": 100,
            "min_length": 1
          }
        },
        {
          "label": "Show Feedback Section",
          "type": "boolean",
          "key": "showFeedbackSection",
          "settings": {
            "default": false,
            "description": "Toggle to show or hide the feedback section",
            "required": false
          }
        },
        {
          "label": "Show Thanks Toast",
          "type": "boolean",
          "key": "showThanksToast",
          "settings": {
            "default": false,
            "description": "Toggle to show or hide the thanks toast after survey completion",
            "required": false
          }
        }
      ],
      "key": "default"
    }
  ],
  "icon_name": "Flag",
  "preview@": "preview.html",
  "__readonly": {
    "key": "nps-survey",
    "valid": true,
    "owner": "user",
    "semver": "0.0.2"
  },
  "$schema": "https://schemas.knock.app/cli/message-type.json"
}
