{
  "name": "JSON repro",
  "description": "Minimal reproduction: can a JSON field default contain an array nested inside an object?",
  "type": "html",
  "visual_block_enabled": true,
  "content@": "content.html",
  "icon_name": "Bug",
  "input_schema": [
    {
      "type": "json",
      "key": "data",
      "label": "Data",
      "settings": {
        "required": false,
        "description": "An object with an items array.",
        "default": {
          "items": ["a", "b"]
        },
        "schema": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array"
            }
          }
        }
      }
    }
  ],
  "$schema": "https://schemas.knock.app/cli/partial.json"
}
