{
  "name": "Video Cover Image",
  "description": "A responsive video thumbnail image with a centered play icon overlay.",
  "type": "html",
  "visual_block_enabled": true,
  "icon_name": "Video",
  "content@": "content.html",
  "input_schema": [
    {
      "type": "image",
      "key": "cover_image",
      "label": "Cover image",
      "settings": {
        "description": "Upload or provide the URL for the video cover image.",
        "required": true
      },
      "url": {
        "type": "url",
        "key": "url",
        "label": "Image URL",
        "settings": {
          "default": "https://images.unsplash.com/photo-1551818255-e6e10975bc17?auto=format&fit=crop&w=1280&q=80",
          "required": true
        }
      },
      "alt": {
        "type": "text",
        "key": "alt",
        "label": "Alt text",
        "settings": {
          "default": "Video cover image",
          "required": false
        }
      },
      "action": {
        "type": "text",
        "key": "action",
        "label": "Image action",
        "settings": {
          "default": "",
          "required": false
        }
      }
    },
    {
      "type": "url",
      "key": "optional_link",
      "label": "Optional link",
      "settings": {
        "default": "",
        "description": "Fallback destination URL used when no image action is set.",
        "required": false
      }
    }
  ],
  "$schema": "https://schemas.knock.app/cli/partial.json"
}
