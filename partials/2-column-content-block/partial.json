{
  "name": "2-column content block",
  "description": "Two side-by-side content sections with matching image, heading, body text, and CTA links.",
  "type": "html",
  "visual_block_enabled": true,
  "icon_name": "Columns2",
  "content@": "content.html",
  "input_schema": [
    {
      "type": "image",
      "key": "block_1_image",
      "label": "Block 1 image",
      "settings": {
        "description": "Image shown above the first content block.",
        "required": true
      },
      "url": {
        "type": "url",
        "key": "url",
        "label": "Image URL",
        "settings": {
          "default": "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&q=80",
          "placeholder": "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&q=80",
          "required": true
        }
      },
      "alt": {
        "type": "text",
        "key": "alt",
        "label": "Alt text",
        "settings": {
          "default": "Team planning a product launch",
          "placeholder": "Team planning a product launch",
          "required": false
        }
      },
      "action": {
        "type": "text",
        "key": "action",
        "label": "Image action",
        "settings": {
          "default": "",
          "required": false
        }
      }
    },
    {
      "type": "text",
      "key": "block_1_header_text",
      "label": "Block 1 header text",
      "settings": {
        "default": "Build your emails faster",
        "description": "Heading shown below the first image.",
        "placeholder": "Build your emails faster",
        "required": true
      }
    },
    {
      "type": "textarea",
      "key": "block_1_paragraph_text",
      "label": "Block 1 paragraph text",
      "settings": {
        "default": "Start with a prebuilt content block, then customize the copy, image, and link.",
        "description": "Paragraph-style text shown below the first heading.",
        "placeholder": "Start with a prebuilt content block, then customize the copy, image, and link.",
        "required": true
      }
    },
    {
      "type": "text",
      "key": "block_1_cta_text",
      "label": "Block 1 CTA text",
      "settings": {
        "default": "Browse templates",
        "description": "Linked CTA text for the first block.",
        "placeholder": "Browse templates",
        "required": true
      }
    },
    {
      "type": "url",
      "key": "block_1_cta_url",
      "label": "Block 1 CTA link",
      "settings": {
        "default": "https://knock.app/templates",
        "description": "Destination URL for the first block CTA.",
        "placeholder": "https://knock.app/templates",
        "required": true
      }
    },
    {
      "type": "image",
      "key": "block_2_image",
      "label": "Block 2 image",
      "settings": {
        "description": "Image shown above the second content block.",
        "required": true
      },
      "url": {
        "type": "url",
        "key": "url",
        "label": "Image URL",
        "settings": {
          "default": "https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=800&q=80",
          "placeholder": "https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=800&q=80",
          "required": true
        }
      },
      "alt": {
        "type": "text",
        "key": "alt",
        "label": "Alt text",
        "settings": {
          "default": "People collaborating around a laptop",
          "placeholder": "People collaborating around a laptop",
          "required": false
        }
      },
      "action": {
        "type": "text",
        "key": "action",
        "label": "Image action",
        "settings": {
          "default": "",
          "required": false
        }
      }
    },
    {
      "type": "text",
      "key": "block_2_header_text",
      "label": "Block 2 header text",
      "settings": {
        "default": "Design every message with confidence",
        "description": "Heading shown below the second image.",
        "placeholder": "Design every message with confidence",
        "required": true
      }
    },
    {
      "type": "textarea",
      "key": "block_2_paragraph_text",
      "label": "Block 2 paragraph text",
      "settings": {
        "default": "Pair each message with a clear CTA so readers know exactly where to go next.",
        "description": "Paragraph-style text shown below the second heading.",
        "placeholder": "Pair each message with a clear CTA so readers know exactly where to go next.",
        "required": true
      }
    },
    {
      "type": "text",
      "key": "block_2_cta_text",
      "label": "Block 2 CTA text",
      "settings": {
        "default": "View best practices",
        "description": "Linked CTA text for the second block.",
        "placeholder": "View best practices",
        "required": true
      }
    },
    {
      "type": "url",
      "key": "block_2_cta_url",
      "label": "Block 2 CTA link",
      "settings": {
        "default": "https://knock.app/blog",
        "description": "Destination URL for the second block CTA.",
        "placeholder": "https://knock.app/blog",
        "required": true
      }
    }
  ],
  "$schema": "https://schemas.knock.app/cli/partial.json"
}
